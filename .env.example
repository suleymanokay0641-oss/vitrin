# ============================================
# Vitrin — Ortam Değişkenleri Şablonu
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env
# ============================================

# --- Veritabanı (Zorunlu) ---
# PostgreSQL bağlantı URL'si
# Format: postgresql://KULLANICI:SIFRE@HOST:PORT/VERITABANI
DATABASE_URL=postgresql://postgres:password@localhost:5432/vitrin

# pg modülü için ayrı değişkenler (opsiyonel — DATABASE_URL yeterli)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=password
# PGDATABASE=vitrin

# --- API Server (Zorunlu) ---
# API sunucu portu (API server için 8080 önerilir)
PORT=8080

# JWT gizli anahtarı — production'da mutlaka değiştirin!
JWT_SECRET=vitrin-jwt-secret-change-in-production

# --- Web Frontend (Zorunlu) ---
# Web arayüzü base path — yerel geliştirmede / kullanın
BASE_PATH=/

# --- Email Servisi (Opsiyonel) ---
# Resend API anahtarı (email doğrulama için)
# https://resend.com adresinden ücretsiz hesap açıp alabilirsiniz
# Yoksa dev modda OTP konsolda görünür
RESEND_API_KEY=

# --- Object Storage (Opsiyonel) ---
# Dosya yükleme için — yoksa uygulamanın temel fonksiyonları çalışır
DEFAULT_OBJECT_STORAGE_BUCKET_ID=
PRIVATE_OBJECT_DIR=
PUBLIC_OBJECT_SEARCH_PATHS=

# --- Web Frontend Notu ---
# Web arayüzü API server'dan farklı bir portta çalışmalıdır.
# Web için PORT=5173 olarak override edin:
#   cd artifacts/price-tracker && PORT=5173 pnpm dev
