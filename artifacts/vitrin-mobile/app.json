{
  "expo": {
    "name": "Vitrin",
    "slug": "vitrin-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vitrin",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "description": "Vitrin — Ürün paylaş, tıklanma kazan. Favori ürünlerini vitrininde sergile, her tıklamada aylık havuzdan pay al.",
    "primaryColor": "#10B981",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#10B981"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.vitrin.mobile",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Profil fotoğrafı yüklemek için kamera erişimi gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Profil fotoğrafı seçmek için fotoğraf kitaplığına erişim gerekiyor.",
        "NSPhotoLibraryAddUsageDescription": "Fotoğraf kaydetmek için fotoğraf kitaplığına erişim gerekiyor.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["vitrin"]
          }
        ]
      }
    },
    "android": {
      "package": "app.vitrin.mobile",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#10B981"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "vitrin.app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "privacyPolicyUrl": "https://vitrin.app/gizlilik",
      "termsUrl": "https://vitrin.app/kullanim-sartlari",
      "supportEmail": "destek@vitrin.app",
      "eas": {
        "projectId": "vitrin-mobile"
      }
    }
  }
}
